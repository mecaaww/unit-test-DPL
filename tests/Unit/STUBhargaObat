<?php
function hitungHargaSetelahDiskon(int $hargaAsli, int $diskonPersen): float
{
    return $hargaAsli - ($hargaAsli * ($diskonPersen / 100));
}

function hitungSubtotal(float $hargaSetelahDiskon, int $jumlah): float
{
    return $hargaSetelahDiskon * $jumlah;
}

// ============================================================
//  STUB: objek tiruan (test double) pengganti Model Eloquent
// ============================================================

function stubObat(int $harga, int $diskonPersen = 0): object
{
    return (object) [
        'harga'         => $harga,
        'diskon_persen' => $diskonPersen,
    ];
}


function stubKeranjangItem(object $obat, int $jumlah): object
{
    return (object) [
        'obat'   => $obat,
        'jumlah' => $jumlah,
    ];
}

// ============================================================
//  TEST CASES
// ============================================================

test('obat tanpa diskon: harga final sama dengan harga asli', function () {
    // ARRANGE — buat stub obat tanpa diskon
    $obatStub = stubObat(harga: 50_000, diskonPersen: 0);

    // ACT
    $hargaFinal = hitungHargaSetelahDiskon(
        (int) $obatStub->harga,
        (int) ($obatStub->diskon_persen ?? 0)
    );

    // ASSERT
    expect($hargaFinal)->toBe(50_000.0);
});

test('obat dengan diskon 10%: harga final berkurang 10%', function () {
    $obatStub = stubObat(harga: 50_000, diskonPersen: 10);

    $hargaFinal = hitungHargaSetelahDiskon(
        (int) $obatStub->harga,
        (int) $obatStub->diskon_persen
    );

    // 50000 - (50000 * 10/100) = 45000
    expect($hargaFinal)->toBe(45_000.0);
});

test('obat dengan diskon 100%: harga final menjadi 0', function () {
    $obatStub = stubObat(harga: 50_000, diskonPersen: 100);

    $hargaFinal = hitungHargaSetelahDiskon(
        (int) $obatStub->harga,
        (int) $obatStub->diskon_persen
    );

    expect($hargaFinal)->toBe(0.0);
});

test('subtotal dihitung benar dari harga final dikali jumlah', function () {
    $obatStub    = stubObat(harga: 20_000, diskonPersen: 25);
    $itemStub    = stubKeranjangItem($obatStub, jumlah: 3);

    $hargaFinal  = hitungHargaSetelahDiskon(
        (int) $itemStub->obat->harga,
        (int) $itemStub->obat->diskon_persen
    );
    $subtotal    = hitungSubtotal($hargaFinal, $itemStub->jumlah);

    // harga final: 20000 - 25% = 15000
    // subtotal   : 15000 * 3  = 45000
    expect($hargaFinal)->toBe(15_000.0)
        ->and($subtotal)->toBe(45_000.0);
});

test('total pesanan dari beberapa item keranjang dihitung benar', function () {
    // Simulasi 2 item di keranjang (seperti looping di PesananController)
    $items = [
        stubKeranjangItem(stubObat(harga: 10_000, diskonPersen: 0),  jumlah: 2),
        stubKeranjangItem(stubObat(harga: 40_000, diskonPersen: 50), jumlah: 1),
    ];

    $totalHarga = 0;
    foreach ($items as $item) {
        $hargaFinal  = hitungHargaSetelahDiskon(
            (int) $item->obat->harga,
            (int) ($item->obat->diskon_persen ?? 0)
        );
        $totalHarga += hitungSubtotal($hargaFinal, $item->jumlah);
    }

    // item 1: 10000 * 2  = 20000
    // item 2: 20000 * 1  = 20000
    // total              = 40000
    expect($totalHarga)->toBe(40_000.0);
});

test('diskon_persen null dianggap 0 (tidak ada diskon)', function () {
    // Stub tanpa properti diskon_persen sama sekali
    $obatStub = (object) ['harga' => 30_000];

    $hargaFinal = hitungHargaSetelahDiskon(
        (int) $obatStub->harga,
        (int) ($obatStub->diskon_persen ?? 0)
    );

    expect($hargaFinal)->toBe(30_000.0);
});
